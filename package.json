{
  "name": "veil-ocr",
  "version": "0.1.0",
  "description": "Offline macOS desktop app that converts image-only PDFs into searchable PDFs using Apple's on-device OCR stack.",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/main/index.cjs",
  "engines": {
    "node": ">=22 <24"
  },
  "author": {
    "name": "Codex"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup --watch --onSuccess \"echo main-build-ready\"",
    "dev:electron": "wait-on tcp:5173 dist/main/index.cjs dist/preload/index.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist/main --watch dist/preload --ext cjs --exec \"electron .\"",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root .",
    "test:watch": "vitest --root .",
    "rebuild:native": "electron-rebuild -f -w @cherrystudio/mac-system-ocr",
    "pack:mac": "npm run build && electron-builder --mac",
    "postinstall": "patch-package && electron-builder install-app-deps && npm run rebuild:native"
  },
  "build": {
    "appId": "com.veil.ocr",
    "productName": "veil",
    "icon": "build/icon.icns",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/fonts",
        "to": "fonts"
      }
    ],
    "asarUnpack": [
      "node_modules/@cherrystudio/mac-system-ocr/**/*",
      "node_modules/bindings/**/*"
    ],
    "npmRebuild": true,
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "patch-package": "^8.0.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cherrystudio/mac-system-ocr": "^0.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@napi-rs/canvas": "^0.1.80",
    "@pdf-lib/fontkit": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "p-queue": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.394",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  }
}
