+static NSDictionary* CreateObservationData(NSString* text, VNConfidence confidence, VNRectangleObservation* rectangleObservation) {
+    CGRect boundingBox = rectangleObservation.boundingBox;
+    return @{
+        @"text": text,
+        @"confidence": @(confidence),
+        @"x": @(boundingBox.origin.x),
+        @"y": @(boundingBox.origin.y),
+        @"width": @(boundingBox.size.width),
+        @"height": @(boundingBox.size.height),
+        @"topLeftX": @(rectangleObservation.topLeft.x),
+        @"topLeftY": @(rectangleObservation.topLeft.y),
+        @"topRightX": @(rectangleObservation.topRight.x),
+        @"topRightY": @(rectangleObservation.topRight.y),
+        @"bottomLeftX": @(rectangleObservation.bottomLeft.x),
+        @"bottomLeftY": @(rectangleObservation.bottomLeft.y),
+        @"bottomRightX": @(rectangleObservation.bottomRight.x),
+        @"bottomRightY": @(rectangleObservation.bottomRight.y)
+    };
+}
+
+static NSArray<NSValue*>* CreateTokenRanges(NSString* text) {
+    NSMutableArray<NSValue*>* tokenRanges = [NSMutableArray array];
+
+    [text enumerateSubstringsInRange:NSMakeRange(0, text.length)
+                             options:NSStringEnumerationByWords | NSStringEnumerationSubstringNotRequired
+                          usingBlock:^(NSString* _Nullable substring, NSRange substringRange, NSRange enclosingRange, BOOL* stop) {
+        if (substringRange.length > 0) {
+            [tokenRanges addObject:[NSValue valueWithRange:substringRange]];
+        }
+    }];
+
+    if (tokenRanges.count == 0 && text.length > 0) {
+        [tokenRanges addObject:[NSValue valueWithRange:NSMakeRange(0, text.length)]];
+    }
+
+    return tokenRanges;
+}
+
+static void AppendRecognizedTextObservations(NSMutableArray* textObservations, VNRecognizedText* recognizedText, VNRecognizedTextObservation* fallbackObservation) {
+    NSString* text = recognizedText.string;
+    if (text.length == 0) {
+        return;
+    }
+
+    NSArray<NSValue*>* tokenRanges = CreateTokenRanges(text);
+    NSUInteger appendedCount = 0;
+
+    for (NSValue* tokenRangeValue in tokenRanges) {
+        NSRange tokenRange = tokenRangeValue.rangeValue;
+        if (tokenRange.length == 0) {
+            continue;
+        }
+
+        NSString* tokenText = [text substringWithRange:tokenRange];
+        NSError* rangeError = nil;
+        VNRectangleObservation* tokenObservation = [recognizedText boundingBoxForRange:tokenRange error:&rangeError];
+
+        if (tokenObservation && tokenText.length > 0) {
+            [textObservations addObject:CreateObservationData(tokenText, recognizedText.confidence, tokenObservation)];
+            appendedCount++;
+        }
+    }
+
+    if (appendedCount == 0) {
+        [textObservations addObject:CreateObservationData(text, recognizedText.confidence, fallbackObservation)];
+    }
+}
