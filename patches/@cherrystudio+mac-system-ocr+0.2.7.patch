+            napi_throw_error(env, NULL, "Invalid options");
+            return NULL;
+        }
+    }
+
+    char* error_message = NULL;
+    size_t language_count = 0;
+    char** languages = get_supported_recognition_languages(&options, &language_count, &error_message);
+
+    if (options.languages && strcmp(options.languages, "en-US") != 0) {
+        free((void*)options.languages);
+    }
+
+    if (error_message) {
+        napi_throw_error(env, NULL, error_message);
+        free(error_message);
+        return NULL;
+    }
+
+    napi_value result;
