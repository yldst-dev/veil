+napi_value GetSupportedRecognitionLanguages(napi_env env, napi_callback_info info) {
+    size_t argc = 1;
+    napi_value args[1];
+    napi_get_cb_info(env, info, &argc, args, NULL, NULL);
+
+    OCROptions options = {
+        .languages = "en-US",
+        .recognition_level = OCR_RECOGNITION_LEVEL_ACCURATE,
+        .min_confidence = 0.0
+    };
+
+    if (argc > 0 && args[0] != NULL) {
+        if (!GetOptionsFromObject(env, args[0], &options)) {
+            napi_throw_error(env, NULL, "Invalid options");
+            return NULL;
+        }
+    }
+
+    char* error_message = NULL;
+    size_t language_count = 0;
+    char** languages = get_supported_recognition_languages(&options, &language_count, &error_message);
+
+    if (options.languages && strcmp(options.languages, "en-US") != 0) {
+        free((void*)options.languages);
+    }
+
+    if (error_message) {
+        napi_throw_error(env, NULL, error_message);
+        free(error_message);
+        return NULL;
+    }
+
+    napi_value result;
+    napi_create_array_with_length(env, language_count, &result);
+
+    for (size_t index = 0; index < language_count; index++) {
+        napi_value locale;
+        napi_create_string_utf8(env, languages[index], NAPI_AUTO_LENGTH, &locale);
+        napi_set_element(env, result, index, locale);
+    }
+
+    free_supported_recognition_languages(languages, language_count);
+    return result;
+}
