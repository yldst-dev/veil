 }
 
+char** get_supported_recognition_languages(const OCROptions* options, size_t* count, char** error) {
+    if (count) {
+        *count = 0;
+    }
+    if (error) {
+        *error = NULL;
+    }
+
+    @autoreleasepool {
+        const OCROptions* opts = options ? options : &DEFAULT_OPTIONS;
+
+        VNRecognizeTextRequest* request = [[VNRecognizeTextRequest alloc] init];
+        request.recognitionLevel = opts->recognition_level == OCR_RECOGNITION_LEVEL_FAST ?
+            VNRequestTextRecognitionLevelFast :
+            VNRequestTextRecognitionLevelAccurate;
+
+        if (@available(macOS 12.0, *)) {
+            request.revision = VNRecognizeTextRequestRevision3;
+        }
+
+        NSError* recognitionError = nil;
+        NSArray<NSString*>* supportedLanguages = [request supportedRecognitionLanguagesAndReturnError:&recognitionError];
+
+        if (recognitionError || !supportedLanguages) {
+            if (error) {
+                NSString* message = recognitionError.localizedDescription ?: @"Failed to fetch supported OCR recognition languages.";
+                *error = strdup(message.UTF8String);
+            }
+            return NULL;
+        }
+
+        NSUInteger languageCount = supportedLanguages.count;
+        if (count) {
+            *count = languageCount;
+        }
+
+        if (languageCount == 0) {
+            return NULL;
+        }
+
+        char** result = (char**)calloc(languageCount, sizeof(char*));
+        if (!result) {
+            if (error) {
+                *error = strdup("Failed to allocate supported OCR recognition language list.");
+            }
+            if (count) {
+                *count = 0;
+            }
+            return NULL;
+        }
+
+        for (NSUInteger index = 0; index < languageCount; index++) {
+            NSString* locale = supportedLanguages[index];
+            result[index] = strdup(locale.UTF8String);
+        }
+
+        return result;
+    }
+}
+
+void free_supported_recognition_languages(char** languages, size_t count) {
+    if (!languages) {
+        return;
+    }
+
+    for (size_t index = 0; index < count; index++) {
+        if (languages[index]) {
+            free(languages[index]);
+        }
+    }
+
+    free(languages);
+}
